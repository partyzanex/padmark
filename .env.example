# padmark configuration — copy to .env and adjust. See docs/release-checklist.md.
# Every value is also a `serve` flag (e.g. PADMARK_ADDR -> --addr). Defaults shown in comments.

# ── Core ──────────────────────────────────────────────────────────────────────
PADMARK_ADDR=:8080                       # listen address; match your proxy/healthcheck
PADMARK_STORAGE=sqlite                   # sqlite | postgres
# sqlite: use an ABSOLUTE path on a persistent volume (the default is relative → lost on redeploy)
# postgres: PADMARK_DSN=postgres://user:pass@db:5432/padmark?sslmode=require
PADMARK_DSN=/var/lib/padmark/padmark.db

PADMARK_LOG_LEVEL=info                   # debug | info | warn | error  (debug shows remote/xff/user)
PADMARK_LOG_FORMAT=json                  # json | text

# ── TLS (terminate in-app; leave empty if the proxy terminates TLS) ───────────
# PADMARK_TLS_CERT=/etc/padmark/tls.crt
# PADMARK_TLS_KEY=/etc/padmark/tls.key
# PADMARK_HTTP_REDIRECT_ADDR=:80         # HTTP->HTTPS redirect listener (only with TLS)
# PADMARK_ALLOWED_HOSTS=example.com,www.example.com   # anti Host-header injection on the redirect

# ── Behind a reverse proxy / load balancer ───────────────────────────────────
# Set to the proxy's SOURCE CIDR (what padmark sees as RemoteAddr). Read it from the request log
# fields `remote=`/`xff=`. Without this, rate-limit shares one bucket (429 storms) and HSTS/Secure
# are not emitted. NEVER use 0.0.0.0/0.
# PADMARK_TRUSTED_PROXIES=10.0.0.0/8

# ── Rate limiting ────────────────────────────────────────────────────────────
PADMARK_RATE_LIMIT=10                    # req/s per client IP; 0 disables (use 0 if proxy CIDR is unknowable)
PADMARK_RATE_BURST=20

# ── Request size limits ──────────────────────────────────────────────────────
PADMARK_MAX_BODY_BYTES=4194304           # 4 MB
PADMARK_MAX_HEADER_BYTES=65536           # 64 KB
PADMARK_READ_TIMEOUT=30                  # seconds
PADMARK_WRITE_TIMEOUT=60                 # seconds

# ── Accounts (TOTP login / /admin / private notes) — OFF by default (public) ──
PADMARK_ENABLE_ACCOUNTS=false            # true → open /setup over HTTPS to create the first admin
# PADMARK_TOTP_ISSUER=padmark
# PADMARK_SESSION_TTL=2592000            # 30 days
# PADMARK_COOKIE_MAX_AGE=7776000         # 90 days
# argon2id cost (only used with accounts); 64 MiB RAM per concurrent login hash
# PADMARK_ARGON2_MEMORY=65536
# PADMARK_ARGON2_TIME=2
# PADMARK_ARGON2_THREADS=1

# ── DEPRECATED: legacy bearer-token write auth (use accounts instead) ─────────
# PADMARK_AUTH_TOKENS=token1,token2
